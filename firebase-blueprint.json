{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and role information",
      "type": "object",
      "properties": {
        "role": {
          "type": "string",
          "enum": ["admin", "user"],
          "description": "The user's role in the application"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address"
        }
      },
      "required": ["role", "email"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and roles"
    }
  }
}
